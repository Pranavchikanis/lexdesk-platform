{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npx prisma generate --schema=packages/database/prisma/schema.prisma"
  },
  "deploy": {
    "startCommand": "node apps/monolith-service/index.js",
    "restartPolicyType": "ON_FAILURE"
  }
}
